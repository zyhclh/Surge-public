# > testflight
http-request ^https?:\/\/testflight\.apple\.com\/v2\/accounts\/.*\/apps\/\d*/builds/\d*/install storefrontId"\s*:\s*".*" storefrontId":"143441-1,29"

# > tianmaojingling
